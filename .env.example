# =============================================================================
# GhostRoute Terminal — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file or share your private keys.
# =============================================================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghostroute

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# RPC Endpoints (replace YOUR_KEY with actual Alchemy/Infura API key)
ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
SOL_RPC=https://api.mainnet-beta.solana.com
AVAX_RPC=https://avax-mainnet.g.alchemy.com/v2/YOUR_KEY
BNB_RPC=https://bsc-dataseed.binance.org

# Contracts (replace with deployed contract addresses)
INTENT_ROUTER=0x0000000000000000000000000000000000000001
FRAGMENT_VAULT=0x0000000000000000000000000000000000000002
ROUTE_REGISTRY=0x0000000000000000000000000000000000000003
SETTLEMENT_VERIFIER=0x0000000000000000000000000000000000000004

# Deployer (⚠️ CHANGE THIS before any testnet/mainnet deployment)
DEPLOYER_PRIVATE_KEY=changeme_to_a_secure_private_key

# 0G Labs (optional integration)
ZG_COMPUTE_ENDPOINT=
ZG_STORAGE_ENDPOINT=
ZG_DA_ENDPOINT=

# Reporting
REPORT_GAS=false
COINMARKETCAP_API_KEY=
