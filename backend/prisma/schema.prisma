}

model SchemaVersion {
  id          String   @id @default(uuid()) @map("id")
  version     String   @unique @map("version")
  description String?  @map("description")
  appliedBy   String?  @map("applied_by")
  checksum    String?  @map("checksum")
  appliedAt   DateTime @default(now()) @map("applied_at")
  duration    Int?     @map("duration") // milliseconds

  @@map("schema_versions")
}

model ExtensionPoint {
  id        String  @id @default(uuid()) @map("id")
  name      String  @unique @map("name")
  schema    Json    @map("schema")
  handler   String  @map("handler")
  enabled   Boolean @default(true) @map("enabled")
  metadata  Json?   @map("metadata")

  @@map("extension_points")
}

// =============================================================================
// TIME-SERIES TABLES (Hypertable-ready)
// These models map to TimescaleDB hypertables. The @map annotation indicates
// the table name. Hypertable creation is done via raw SQL migrations.
// =============================================================================

model PriceHistory {
  id        String   @id @default(uuid()) @map("id")
  token     String   @map("token")
  price     Float    @map("price")
  source    String   @default("defillama") @map("source")
  volume    Float?   @map("volume")
  marketCap Float?   @map("market_cap")
  timestamp DateTime @default(now()) @map("timestamp")

  @@index([token, timestamp])
  @@index([timestamp])
  @@map("price_history")
}

model GasPriceHistory {
  id          String   @id @default(uuid()) @map("id")
  chainId     String   @map("chain_id")
  gasPrice    Float    @map("gas_price")
  baseFee     Float?   @map("base_fee")
  priorityFee Float?   @map("priority_fee")
  maxFeePerGas Float?  @map("max_fee_per_gas")
  gasUsed     Float?   @map("gas_used")
  blockNumber Int?     @map("block_number")
  timestamp   DateTime @default(now()) @map("timestamp")

  chain Chain @relation(fields: [chainId], references: [id])

  @@index([chainId, timestamp])
  @@index([timestamp])
  @@map("gas_price_history")
}

model RoutePerformanceHistory {
  id           String   @id @default(uuid()) @map("id")
  routeId      String   @map("route_id")
  latency      Float    @map("latency")
  successRate  Float    @map("success_rate")
  volume       Float    @map("volume")
  executionCount Int    @default(1) @map("execution_count")
  avgGasUsed   Float?   @map("avg_gas_used")
  timestamp    DateTime @default(now()) @map("timestamp")

  route Route @relation(fields: [routeId], references: [id])

  @@index([routeId, timestamp])
  @@index([timestamp])
  @@map("route_performance_history")
}

model RiskScoreHistory {
  id           String   @id @default(uuid()) @map("id")
  entityId     String   @map("entity_id")
  entityType   String   @map("entity_type")
  score        Float    @map("score")
  factors      Json?    @map("factors")
  timestamp    DateTime @default(now()) @map("timestamp")

  @@index([entityId, entityType, timestamp])
  @@index([timestamp])
  @@map("risk_score_history")
}

model RelayerPerformanceHistory {
  id          String   @id @default(uuid()) @map("id")
  relayerId   String   @map("relayer_id")
  settlementId String? @map("settlement_id")
  latency     Float    @map("latency")
  success     Boolean  @default(true) @map("success")
  gasUsed     Float?   @map("gas_used")
  fee         Float?   @map("fee")
  timestamp   DateTime @default(now()) @map("timestamp")

  relayer   Relayer    @relation(fields: [relayerId], references: [id])
  settlement Settlement? @relation(fields: [settlementId], references: [id])

  @@index([relayerId, timestamp])
  @@index([timestamp])
  @@map("relayer_performance_history")
}
