generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}


datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgcrypto]
}

// =============================================================================
// ENUMS
// =============================================================================

enum ChainStatus {
  healthy
  degraded
  paused
  halted
}

enum RouteStatus {
  active
  inactive
  degraded
  paused
  deprecated
}

enum IntentState {
  created
  quoted
  auctioning
  executing
  settled
  failed
  expired
  cancelled
}

enum BidState {
  pending
  accepted
  rejected
  withdrawn
  expired
}

enum SettlementState {
  pending
  submitted
  confirmed
  finalized
  failed
  disputed
}

enum PrivacyLevel {
  standard
  private
  stealth
  shielded
}

enum Severity {
  info
  warning
  critical
  emergency
}

enum RelayerStatus {
  active
  inactive
  jailed
  slashed
  retired
}

enum ExecutionFragmentState {
  pending
  routing
  swapping
  bridging
  settling
  completed
  failed
  rerouted
}

enum AuctionState {
  pending
  open
  closed
  awarded
  cancelled
}

enum ZkProofState {
  generated
  submitted
  verified
  failed
  anchored
}

enum ConsensusRoundState {
  started
  awaiting_votes
  finalized
  failed
}

enum ScheduleTaskState {
  active
  paused
  completed
  failed
  cancelled
}

enum ApiKeyPermission {
  read
  write
  admin
  restricted
}

enum WebhookEventType {
  execution_completed
  settlement_finalized
  anomaly_detected
  relayer_status_change
  position_liquidated
  route_deprecated
}

enum StrategyConditionOperator {
  gt
  gte
  lt
  lte
  eq
  neq
  contains
  in_range
}

// =============================================================================
// USER & MULTI-WALLET (Upgrade 10)
// =============================================================================

model User {
  id         String   @id @default(uuid()) @map("id")
  address    String   @unique @map("address")
  email      String?  @unique @map("email")
  role       String   @default("user") @map("role")
  tier       String   @default("free") @map("tier")
  permissions Json?    @default("[]") @map("permissions")
  metadata   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  intents             Intent[]
  apiKeys             ApiKey[]
  webhooks            IntegrationWebhook[]
  workspaces          WorkspaceConfig[]
  savedLayouts        SavedLayout[]
  strategies          RouteStrategy[]
  positions           Position[]
  approvalRequests    ApprovalWorkflow[]      @relation("ApprovalRequester")
  approvalActions     ApprovalWorkflow[]      @relation("ApprovalApprover")
  aiChats             AiChat[]
  permissionAudits    PermissionAudit[]
  reviewedAudits      PermissionAudit[]      @relation("PermissionReviewer")
  auditLogs           AuditLog[]

  @@map("users")
}

model PermissionPolicy {
  id        String   @id @default(uuid()) @map("id")
  name      String   @unique @map("name")
  resource  String   @map("resource")
  effect    String   @map("effect") // allow | deny
  priority  Int      @default(0) @map("priority")
  conditions Json?   @map("conditions")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([resource, effect])
  @@map("permission_policies")
}

model ApprovalWorkflow {
  id           String    @id @default(uuid()) @map("id")
  requesterId  String    @map("requester_id")
  approverId   String?   @map("approver_id")
  action       String    @map("action")
  params       Json      @map("params")
  state        String    @default("pending") @map("state") // pending | approved | rejected | expired
  reason       String?   @map("reason")
  expiresAt    DateTime? @map("expires_at")
  decidedAt    DateTime? @map("decided_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  requester User @relation("ApprovalRequester", fields: [requesterId], references: [id])
  approver  User? @relation("ApprovalApprover", fields: [approverId], references: [id])

  @@index([requesterId, state])
  @@index([approverId, state])
  @@map("approval_workflows")
}

// =============================================================================
// CHAIN (Enhanced - Upgrade 20)
// =============================================================================

model Chain {
  id              String      @id @default(uuid()) @map("id")
  name            String      @unique @map("name")
  shortName       String      @map("short_name")
  chainId         Int         @unique @map("chain_id")
  rpcUrl          String?     @map("rpc_url")
  wsUrl           String?     @map("ws_url")
  explorerUrl     String?     @map("explorer_url")
  status          ChainStatus @default(healthy) @map("status")
  liquidity       Float       @default(0) @map("liquidity")
  spread          Float       @default(0) @map("spread")
  gas             Float       @default(0) @map("gas")
  bridgeFee       Float       @default(0.05) @map("bridge_fee")
  slippage        Float       @default(0.01) @map("slippage")
  latency         Int         @default(0) @map("latency")
  privacy         Int         @default(50) @map("privacy")
  mev             Int         @default(50) @map("mev")
  eta             String      @default("0s") @map("eta")
  blockTime       Float?      @map("block_time")
  nativeCurrency  String?     @default("ETH") @map("native_currency")
  decimals        Int?        @default(18) @map("decimals")
  isTestnet       Boolean     @default(false) @map("is_testnet")
  isDeprecated    Boolean     @default(false) @map("is_deprecated")
  metadata        Json?       @map("metadata")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  sourceRoutes        Route[]              @relation("SourceChain")
  destRoutes          Route[]              @relation("DestChain")
  liquidityPools      LiquidityPool[]
  sourceSettlements   Settlement[]         @relation("SettlementSource")
  destSettlements     Settlement[]         @relation("SettlementDest")
  encryptedTxs        EncryptedTx[]
  graphNodes          GraphNode[]
  allocationRules     AllocationRule[]
  liquidityForecasts  LiquidityForecast[]
  gasPriceHistory     GasPriceHistory[]

  @@index([status])
  @@index([chainId])
  @@map("chains")
}

// =============================================================================
// ROUTE (Enhanced - Upgrade 15)
// =============================================================================

model Route {
  id              String      @id @default(uuid()) @map("id")
  name            String      @map("name")
  sourceChainId   String      @map("source_chain_id")
  destChainId     String      @map("dest_chain_id")
  maxAmount       Float       @map("max_amount")
  minAmount       Float       @map("min_amount")
  avgLatency      Float       @default(0) @map("avg_latency")
  successRate     Float       @default(100) @map("success_rate")
  totalVolume     Float       @default(0) @map("total_volume")
  totalExecs      Int         @default(0) @map("total_execs")
  status          RouteStatus @default(active) @map("status")
  category        String?     @map("category")
  tags            String[]    @map("tags")
  bridges         String      @default("[]") @map("bridges")
  dexes           String      @default("[]") @map("dexes")
  costModel       Json?       @map("cost_model")
  riskProfile     Json?       @map("risk_profile")
  version         Int         @default(1) @map("version")
  deprecatedAt    DateTime?   @map("deprecated_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  sourceChain Chain  @relation("SourceChain", fields: [sourceChainId], references: [id])
  destChain   Chain  @relation("DestChain", fields: [destChainId], references: [id])

  settlements           Settlement[]
  pathHistory           PathHistory[]
  oldRouteEvents        RerouteEvent[]         @relation("OldRoute")
  newRouteEvents        RerouteEvent[]         @relation("NewRoute")
  strategyExecutionLogs StrategyExecutionLog[]
  performanceHistory    RoutePerformanceHistory[]

  @@index([sourceChainId, destChainId])
  @@index([status])
  @@index([totalVolume])
  @@index([successRate, avgLatency])
  @@map("routes")
}

// =============================================================================
// INTENT EXECUTION (Upgrade 1)
// =============================================================================

model Intent {
  id              String      @id @default(uuid()) @map("id")
  userId          String      @map("user_id")
  tokenIn         String      @map("token_in")
  tokenOut        String      @map("token_out")
  amountIn        Float       @map("amount_in")
  minAmountOut    Float       @map("min_amount_out")
  sourceChainId   String      @map("source_chain_id")
  destChainId     String      @map("dest_chain_id")
  privacyLevel    PrivacyLevel @default(standard) @map("privacy_level")
  fragmented      Boolean     @default(false) @map("fragmented")
  state           IntentState @default(created) @map("state")
  slippageTolerance Float?    @default(0.01) @map("slippage_tolerance")
  deadline        DateTime?   @map("deadline")
  metadata        Json?       @map("metadata")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            User?               @relation(fields: [userId], references: [id])
  fragments       IntentFragment[]
  bids            SolverBid[]
  auction         Auction?
  executionReport AiExecutionReport?
  executionSnapshot ExecutionSnapshot[]
  rerouteEvents   RerouteEvent[]
  strategyLogs    StrategyExecutionLog[]

  @@index([userId])
  @@index([state])
  @@index([sourceChainId, destChainId])
  @@index([createdAt])
  @@map("intents")
}

model IntentFragment {
  id        String               @id @default(uuid()) @map("id")
  intentId  String               @map("intent_id")
  token     String               @map("token")
  amount    Float                @map("amount")
  targetDex String               @default("") @map("target_dex")
  state     ExecutionFragmentState @default(pending) @map("state")
  routeId   String?              @map("route_id")
  settled   Boolean              @default(false) @map("settled")
  txHash    String?              @map("tx_hash")
  metadata  Json?                @map("metadata")

  intent        Intent                 @relation(fields: [intentId], references: [id], onDelete: Cascade)
  traces        FragmentTrace[]
  stateMachines FragmentStateMachine[]

  @@index([intentId])
  @@index([state])
  @@index([routeId])
  @@map("intent_fragments")
}

model SolverBid {
  id        String   @id @default(uuid()) @map("id")
  intentId  String   @map("intent_id")
  solverId  String   @map("solver_id")
  amount    Float    @map("amount")
  fee       Float    @map("fee")
  tokenOut  Float?   @map("token_out")
  deadline  DateTime? @map("deadline")
  state     BidState @default(pending) @map("state")
  signature String?  @map("signature")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  intent     Intent         @relation(fields: [intentId], references: [id], onDelete: Cascade)
  solver     SolverProfile? @relation(fields: [solverId], references: [id])
  wonAuction Auction?

  @@index([intentId, state])
  @@index([solverId])
  @@index([amount])
  @@map("solver_bids")
}

model Auction {
  id            String       @id @default(uuid()) @map("id")
  intentId      String       @unique @map("intent_id")
  startTime     DateTime     @map("start_time")
  endTime       DateTime     @map("end_time")
  minBid        Float?       @map("min_bid")
  winningBidId  String?      @unique @map("winning_bid_id")
  state         AuctionState @default(pending) @map("state")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  intent      Intent     @relation(fields: [intentId], references: [id], onDelete: Cascade)
  winningBid  SolverBid? @relation(fields: [winningBidId], references: [id])

  @@index([state, endTime])
  @@map("auctions")
}

// =============================================================================
// SOLVER MARKETPLACE (Upgrade 8)
// =============================================================================

model SolverProfile {
  id           String   @id @default(uuid()) @map("id")
  userId       String?  @map("user_id")
  name         String   @map("name")
  endpoint     String?  @map("endpoint")
  capabilities String[] @map("capabilities")
  stake        Float    @default(0) @map("stake")
  reputation   Float    @default(0) @map("reputation")
  totalBids    Int      @default(0) @map("total_bids")
  wonBids      Int      @default(0) @map("won_bids")
  totalVolume  Float    @default(0) @map("total_volume")
  status       String   @default("active") @map("status")
  metadata     Json?    @map("metadata")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bids          SolverBid[]
  rewards       SolverReward[]
  reputationHistory SolverReputationHistory[]

  @@index([reputation])
  @@index([status])
  @@index([totalVolume])
  @@map("solver_profiles")
}

model SolverReward {
  id        String   @id @default(uuid()) @map("id")
  solverId  String   @map("solver_id")
  amount    Float    @map("amount")
  reason    String   @map("reason")
  txHash    String?  @map("tx_hash")
  awardedAt DateTime @default(now()) @map("awarded_at")

  solver SolverProfile @relation(fields: [solverId], references: [id], onDelete: Cascade)

  @@index([solverId])
  @@index([awardedAt])
  @@map("solver_rewards")
}

model SolverReputationHistory {
  id         String   @id @default(uuid()) @map("id")
  solverId   String   @map("solver_id")
  score      Float    @map("score")
  change     Float    @map("change")
  reason     String   @map("reason")
  recordedAt DateTime @default(now()) @map("recorded_at")

  solver SolverProfile @relation(fields: [solverId], references: [id], onDelete: Cascade)

  @@index([solverId, recordedAt])
  @@map("solver_reputation_history")
}

// =============================================================================
// SETTLEMENT (Enhanced - Upgrade 9)
// =============================================================================

model Settlement {
  id              String          @id @default(uuid()) @map("id")
  txHash          String          @unique @map("tx_hash")
  routeId         String          @map("route_id")
  proofHash       String          @map("proof_hash")
  sourceChainId   String          @map("source_chain_id")
  destChainId     String          @map("dest_chain_id")
  relayerAddress  String          @map("relayer_address")
  amount          Float           @map("amount")
  fee             Float           @map("fee")
  state           SettlementState @default(pending) @map("state")
  confirmations   Int             @default(0) @map("confirmations")
  blockNumber     Int?            @map("block_number")
  finalityRisk    Float?          @default(0) @map("finality_risk")
  metadata        Json?           @map("metadata")
  createdAt       DateTime        @default(now()) @map("created_at")

  sourceChain Chain @relation("SettlementSource", fields: [sourceChainId], references: [id])
  destChain   Chain @relation("SettlementDest", fields: [destChainId], references: [id])
  route       Route @relation(fields: [routeId], references: [id])
  zkProof     ZkProof?
  relayerPerformance RelayerPerformanceHistory[]

  @@index([routeId])
  @@index([state])
  @@index([sourceChainId, destChainId])
  @@index([createdAt])
  @@map("settlements")
}

model ZkProof {
  id                String       @id @default(uuid()) @map("id")
  settlementId      String       @unique @map("settlement_id")
  proof             String       @map("proof")
  publicInputs      Json         @map("public_inputs")
  publicOutputs     Json?        @map("public_outputs")
  verifyingKey      String       @map("verifying_key")
  state             ZkProofState @default(generated) @map("state")
  provingTime       Int?         @map("proving_time")
  verificationGas   Int?         @map("verification_gas")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  settlement    Settlement             @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  attestations  VerifierAttestation[]
  chainLinks    AttestationChain[]     @relation("ChildAttestation")

  @@map("zk_proofs")
}

model VerifierAttestation {
  id           String   @id @default(uuid()) @map("id")
  zkProofId    String   @map("zk_proof_id")
  verifier     String   @map("verifier")
  attestation  String   @map("attestation")
  signature    String?  @map("signature")
  timestamp    DateTime @default(now()) @map("timestamp")
  state        String   @default("pending") @map("state")

  zkProof ZkProof @relation(fields: [zkProofId], references: [id], onDelete: Cascade)

  @@index([zkProofId, verifier])
  @@map("verifier_attestations")
}

model AttestationChain {
  id                    String   @id @default(uuid()) @map("id")
  zkProofId             String   @map("zk_proof_id")
  previousAttestationId String?  @map("previous_attestation_id")
  root                  String   @map("root")
  depth                 Int      @default(0) @map("depth")
  createdAt             DateTime @default(now()) @map("created_at")

  zkProof             ZkProof           @relation("ChildAttestation", fields: [zkProofId], references: [id], onDelete: Cascade)
  previousAttestation AttestationChain?  @relation("ParentAttestation", fields: [previousAttestationId], references: [id])
  childAttestations   AttestationChain[] @relation("ParentAttestation")

  @@index([zkProofId])
  @@index([root])
  @@map("attestation_chains")
}

// =============================================================================
// PRIVATE MEMPOOL (Upgrade 2)
// =============================================================================

model EncryptedTx {
  id               String   @id @default(uuid()) @map("id")
  bundleId         String?  @map("bundle_id")
  chainId          String   @map("chain_id")
  encryptedPayload String   @map("encrypted_payload")
  commitmentHash   String   @map("commitment_hash")
  submitter        String   @map("submitter")
  ordering         Int      @default(0) @map("ordering")
  revealedAt       DateTime? @map("revealed_at")
  txHash           String?  @map("tx_hash")
  status           String   @default("sealed") @map("status")
  createdAt        DateTime @default(now()) @map("created_at")

  bundle SealedBundle? @relation(fields: [bundleId], references: [id])
  chain  Chain         @relation(fields: [chainId], references: [id])

  @@unique([commitmentHash, chainId])
  @@index([chainId, status])
  @@index([bundleId])
  @@map("encrypted_txs")
}

model SealedBundle {
  id              String    @id @default(uuid()) @map("id")
  commitmentRoot  String    @unique @map("commitment_root")
  sealedAt        DateTime  @default(now()) @map("sealed_at")
  revealAt        DateTime? @map("reveal_at")
  revealedAt      DateTime? @map("revealed_at")
  state           String    @default("sealed") @map("state") // sealed | revealed | landed | failed
  signature       String?   @map("signature")
  metadata        Json?     @map("metadata")

  encryptedTxs EncryptedTx[]

  @@index([state])
  @@index([sealedAt])
  @@map("sealed_bundles")
}

// =============================================================================
// LIQUIDITY POOL (Enhanced - Upgrade 11)
// =============================================================================

model LiquidityPool {
  id           String @id @default(uuid()) @map("id")
  chainId      Int    @map("chain_id")
  token        String @map("token")
  tokenAddress String? @map("token_address")
  depth        Float  @default(0) @map("depth")
  utilization  Float  @default(0) @map("utilization")
  apy          Float  @default(0) @map("apy")
  volume24h    Float  @default(0) @map("volume_24h")
  fee          Float  @default(0.003) @map("fee")
  price        Float? @map("price")
  liquidity    Float? @map("liquidity")
  metadata     Json?  @map("metadata")

  chain Chain @relation(fields: [chainId], references: [chainId])

  @@unique([chainId, token])
  @@index([chainId, utilization])
  @@index([depth])
  @@map("liquidity_pools")
}

model LiquidityPredictionModel {
  id            String   @id @default(uuid()) @map("id")
  name          String   @map("name")
  version       String   @map("version")
  modelType     String   @map("model_type")
  parameters    Json     @map("parameters")
  accuracy      Float    @default(0) @map("accuracy")
  mape          Float?   @map("mape") // Mean Absolute Percentage Error
  lastTrainedAt DateTime @map("last_trained_at")
  trainingData  Json?    @map("training_data")
  status        String   @default("active") @map("status")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  forecasts       LiquidityForecast[]
  accuracyRecords ForecastAccuracy[]

  @@index([name, version])
  @@index([status])
  @@map("liquidity_prediction_models")
}

model LiquidityForecast {
  id                 String   @id @default(uuid()) @map("id")
  modelId            String   @map("model_id")
  chainId            String   @map("chain_id")
  token              String   @map("token")
  predictedDepth     Float    @map("predicted_depth")
  predictedUtilization Float @map("predicted_utilization")
  predictedVolume    Float?   @map("predicted_volume")
  predictedFee       Float?   @map("predicted_fee")
  confidenceInterval Json?    @map("confidence_interval")
  forecastTime       DateTime @map("forecast_time")
  horizon            String   @default("1h") @map("horizon")
  createdAt          DateTime @default(now()) @map("created_at")

  model LiquidityPredictionModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  chain Chain                     @relation(fields: [chainId], references: [id])

  @@index([modelId, forecastTime])
  @@index([chainId, token, forecastTime])
  @@map("liquidity_forecasts")
}

model ForecastAccuracy {
  id                String   @id @default(uuid()) @map("id")
  modelId           String   @map("model_id")
  actualDepth       Float    @map("actual_depth")
  predictedDepth    Float    @map("predicted_depth")
  actualUtilization Float?   @map("actual_utilization")
  predictedUtilization Float? @map("predicted_utilization")
  error             Float    @map("error")
  errorPct          Float?   @map("error_pct")
  calculatedAt      DateTime @default(now()) @map("calculated_at")

  model LiquidityPredictionModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId, calculatedAt])
  @@map("forecast_accuracy")
}

// =============================================================================
// GRAPH ENGINE (Upgrade 3)
// =============================================================================

model GraphNode {
  id        String @id @default(uuid()) @map("id")
  chainId   String @map("chain_id")
  token     String @map("token")
  nodeType  String @default("pool") @map("node_type")
  metadata  Json?  @map("metadata")

  chain Chain @relation(fields: [chainId], references: [id])

  sourceEdges GraphEdge[]   @relation("SourceNode")
  destEdges   GraphEdge[]   @relation("DestNode")
  sourcePaths PathHistory[] @relation("PathSource")
  destPaths   PathHistory[] @relation("PathDest")

  @@unique([chainId, token, nodeType])
  @@index([chainId])
  @@map("graph_nodes")
}

model GraphEdge {
  id           String   @id @default(uuid()) @map("id")
  sourceNodeId String   @map("source_node_id")
  destNodeId   String   @map("dest_node_id")
  weight       Float    @default(0) @map("weight")
  bridge       String?  @map("bridge")
  latency      Float?   @map("latency")
  fee          Float?   @map("fee")
  liquidity    Float?   @map("liquidity")
  isActive     Boolean  @default(true) @map("is_active")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sourceNode GraphNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  destNode   GraphNode @relation("DestNode", fields: [destNodeId], references: [id], onDelete: Cascade)

  @@index([sourceNodeId, destNodeId])
  @@index([isActive, weight])
  @@map("graph_edges")
}

model PathHistory {
  id           String   @id @default(uuid()) @map("id")
  sourceNodeId String   @map("source_node_id")
  destNodeId   String   @map("dest_node_id")
  routeId      String   @map("route_id")
  latency      Float    @map("latency")
  gasUsed      Float?   @map("gas_used")
  success      Boolean  @default(true) @map("success")
  timestamp    DateTime @default(now()) @map("timestamp")

  sourceNode GraphNode @relation("PathSource", fields: [sourceNodeId], references: [id])
  destNode   GraphNode @relation("PathDest", fields: [destNodeId], references: [id])
  route      Route     @relation(fields: [routeId], references: [id])

  @@index([sourceNodeId, destNodeId, timestamp])
  @@index([routeId, timestamp])
  @@map("path_history")
}

// =============================================================================
// AI COPILOT (Upgrade 4)
// =============================================================================

model AiRecommendation {
  id          String   @id @default(uuid()) @map("id")
  userId      String   @map("user_id")
  type        String   @map("type") // route | gas | liquidity | risk | strategy
  title       String   @map("title")
  description String   @map("description")
  data        Json     @map("data")
